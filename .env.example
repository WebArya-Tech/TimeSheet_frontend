# ============================================================
# FRONTEND ENVIRONMENT CONFIGURATION EXAMPLE
# ============================================================
# Copy this file to .env and update values for your environment

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
VITE_APP_NAME="Time Sheet Management System"
VITE_ENVIRONMENT="development"

# ============================================================
# API CONFIGURATION
# ============================================================
# Update with your backend API URL
VITE_API_BASE_URL="http://localhost:9079"
VITE_API_V1_PREFIX="/api/v1"

# ============================================================
# FRONTEND SERVER CONFIGURATION
# ============================================================
# 9078 for production, 5173 for Vite dev server
VITE_PORT=9078

# ============================================================
# FEATURES
# ============================================================
VITE_ENABLE_MOCK_API=false
VITE_DEBUG_MODE=true

# ============================================================
# THEME
# ============================================================
VITE_THEME="light"
